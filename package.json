{
  "name": "js-engines-playground",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "dev": "next dev -p 8000",
    "build": "next build",
    "vercel-build": "bash -lc \"npm i -g jsvu && jsvu --os=linux64 --engines=v8,javascriptcore,quickjs || true; rm -rf .jsvu; mkdir -p .jsvu; cp -R ~/.jsvu/. .jsvu/ || true; node scripts/patch-jsvu-bin.mjs; next build\"",
    "start": "next start -p 8000",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,yml,md}\"",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/lang-javascript": "^6.0.1",
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "2.0.16",
    "@monaco-editor/react": "4.7.0",
    "@replit/codemirror-vim": "^6.0.1",
    "@tailwindcss/forms": "0.5.11",
    "@uiw/react-codemirror": "^4.25.4",
    "execa": "5.1.1",
    "lodash.debounce": "^4.0.8",
    "next": "^16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/lodash.debounce": "^4.0.7",
    "@types/node": "20.10.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.23",
    "husky": "^8.0.3",
    "lint-staged": "^16.4.0",
    "postcss": "8.5.6",
    "prettier": "3.1.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,md,css,html,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "7.0.5"
    }
  }
}
